---
---

<section class="pt-32 pb-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-teal-400 bg-teal-400/10 rounded-full border border-teal-400/20">
      AI-Powered Browser Automation
    </div>
    <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
      Automate any web task<br />
      <span class="text-teal-400">with natural language</span>
    </h1>
    <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-10">
      VibPage is a CLI tool that lets you automate browser tasks using AI.
      Describe what you want to do, and VibPage does it — filling forms, posting to social media,
      scraping data, and more.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#pricing" class="px-8 py-3 text-base font-semibold bg-teal-500 hover:bg-teal-400 text-gray-950 rounded-lg transition">
        Get Started
      </a>
      <div class="flex items-center gap-3 px-6 py-3 bg-gray-900 rounded-lg border border-gray-800 font-mono text-sm">
        <span class="text-gray-500">$</span>
        <span class="text-gray-300">npx vibpage</span>
        <button onclick="navigator.clipboard.writeText('npx vibpage')" class="text-gray-500 hover:text-white transition cursor-pointer" title="Copy">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>
