---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Sign In - VibPage">
  <Header />
  <main class="pt-24 pb-20 px-6 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md">
      <div id="clerk-sign-in">
        <p class="text-gray-400 text-center">Loading...</p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script
  is:inline
  async
  crossorigin="anonymous"
  data-clerk-publishable-key="pk_live_Y2xlcmsudmlicGFnZS5jb20k"
  src="https://clerk.vibpage.com/npm/@clerk/clerk-js@5/dist/clerk.browser.js"
  type="text/javascript"
></script>
<script is:inline>
  window.addEventListener('load', async function () {
    try {
      await Clerk.load();

      var params = new URLSearchParams(window.location.search);
      var redirectUri = params.get('redirect_uri');

      if (Clerk.user && redirectUri) {
        var token = await Clerk.session.getToken();
        if (token) {
          window.location.href = redirectUri + '?token=' + encodeURIComponent(token);
          return;
        }
      }

      if (Clerk.user && !redirectUri) {
        window.location.href = '/';
        return;
      }

      var signInDiv = document.getElementById('clerk-sign-in');
      signInDiv.innerHTML = '';
      Clerk.mountSignIn(signInDiv);
    } catch (err) {
      document.getElementById('clerk-sign-in').innerHTML =
        '<p style="color:red;text-align:center">Failed to load: ' + err.message + '</p>';
    }
  });
</script>
