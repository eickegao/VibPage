---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Payment Cancelled - VibPage">
  <Header />
  <main class="pt-24 pb-20 px-6 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-md">
      <h1 class="text-3xl font-bold mb-4">Payment Cancelled</h1>
      <p class="text-gray-400 mb-8">
        No worries! You can subscribe anytime.
      </p>
      <a href="/#pricing" class="inline-block px-6 py-3 bg-teal-500 hover:bg-teal-400 text-gray-950 rounded-lg font-medium transition">
        View Plans
      </a>
    </div>
  </main>
  <Footer />
</Layout>
