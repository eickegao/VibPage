---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Payment Successful - VibPage">
  <Header />
  <main class="pt-24 pb-20 px-6 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-md">
      <div class="text-6xl mb-6">&#10003;</div>
      <h1 class="text-3xl font-bold mb-4">Payment Successful!</h1>
      <p class="text-gray-400 mb-8">
        Your subscription is now active. You can start using VibPage right away.
      </p>
      <div class="space-y-4">
        <p class="text-sm text-gray-500">
          Run this in your terminal to get started:
        </p>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
          <code class="text-teal-400">npx vibpage</code>
        </div>
        <a href="/" class="inline-block mt-4 px-6 py-3 bg-teal-500 hover:bg-teal-400 text-gray-950 rounded-lg font-medium transition">
          Back to Home
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
