---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Sign Up - VibPage">
  <Header />
  <main class="pt-24 pb-20 px-6 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md">
      <div id="clerk-sign-up">
        <p class="text-gray-400 text-center">Loading...</p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script
  is:inline
  async
  crossorigin="anonymous"
  data-clerk-publishable-key="pk_live_Y2xlcmsudmlicGFnZS5jb20k"
  src="https://clerk.vibpage.com/npm/@clerk/clerk-js@5/dist/clerk.browser.js"
  type="text/javascript"
></script>
<script is:inline>
  window.addEventListener('load', async function () {
    try {
      await Clerk.load();

      if (Clerk.user) {
        window.location.href = '/';
        return;
      }

      var signUpDiv = document.getElementById('clerk-sign-up');
      signUpDiv.innerHTML = '';
      Clerk.mountSignUp(signUpDiv);
    } catch (err) {
      document.getElementById('clerk-sign-up').innerHTML =
        '<p style="color:red;text-align:center">Failed to load: ' + err.message + '</p>';
    }
  });
</script>
