{
  "name": "vibpage-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create vibpage",
    "db:migrate": "wrangler d1 execute vibpage --local --file=./migrations/001_init.sql",
    "db:migrate:remote": "wrangler d1 execute vibpage --remote --file=./migrations/001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250312.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.72.0"
  },
  "dependencies": {
    "jose": "^6.2.1",
    "stripe": "^20.4.1"
  }
}
